// type_infer_3: binary search on a reference-array parameter.
//
// `bsearch` has a meaningful algorithmic body — three locals, a while
// loop with two internal return sites, plus an after-loop return for
// the miss case. None of the return types are written explicitly.
//
// Inference challenges exercised:
//
//   * A function parameter of reference type `&[i32]` coexists with
//     an inferred return type: signature registration must leave the
//     return as a fresh type variable while the parameter stays the
//     concrete reference type.
//   * Three different return statements on different control-flow
//     paths must all unify into the same [bsearch_ret] equivalence
//     class.
//   * The caller uses `bsearch(&arr, n, target)` as an argument to
//     `std::putint`, so [bsearch_ret] = i32 must be visible to the
//     caller's type-check as well.
use std;

fn bsearch(arr: &[i32], n: i32, target: i32) {
    let lo = 0;
    let hi = n - 1;
    while lo <= hi {
        let mid = (lo + hi) / 2;
        if arr[mid] == target {
            return mid;
        }
        if arr[mid] < target {
            lo = mid + 1;
        } else {
            hi = mid - 1;
        }
    }
    return 0 - 1;
}

fn main() -> i32 {
    let arr: [i32; 8] = [1, 3, 5, 7, 9, 11, 13, 15];
    std::putint(bsearch(&arr, 8, 7));
    std::putch(32);
    std::putint(bsearch(&arr, 8, 1));
    std::putch(32);
    std::putint(bsearch(&arr, 8, 15));
    std::putch(32);
    std::putint(bsearch(&arr, 8, 4));
    std::putch(32);
    std::putint(bsearch(&arr, 8, 20));
    std::putch(10);
    return 0;
}
