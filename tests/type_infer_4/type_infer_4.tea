// type_infer_4: a prime-number module of three inferred-return
// functions that form a linear cross-function dependency chain.
//
//     is_prime  →  next_prime  →  nth_prime
//
// Every function has multiple return sites along different control-
// flow paths, and both `next_prime` and `nth_prime` use the results
// of earlier functions inside while-loop conditions and updates —
// a context that the pure "default to Void" pipeline can never
// handle (`while is_prime(c) == 0` requires `is_prime` to return an
// i32).
//
// Inference challenges exercised:
//
//   * A three-level cross-function chain where each level's return
//     type must be resolved before it is consumed by the next.
//   * `is_prime` has three different return sites (early-return for
//     n < 2, mid-loop return 0 for composites, post-loop return 1
//     for primes) that all must unify to the same equivalence class.
//   * Inferred-return calls used inside loop conditions, as well as
//     inside loop bodies as RHS values, exercising the full set of
//     contexts where a call-expression may appear.
use std;

fn is_prime(n: i32) {
    if n < 2 {
        return 0;
    }
    let d = 2;
    let bound = d * d;
    while bound <= n {
        let r = n - (n / d) * d;
        if r == 0 {
            return 0;
        }
        d = d + 1;
        bound = d * d;
    }
    return 1;
}

fn next_prime(n: i32) {
    let c = n + 1;
    let prime = is_prime(c);
    while prime == 0 {
        c = c + 1;
        prime = is_prime(c);
    }
    return c;
}

fn nth_prime(k: i32) {
    let p = 1;
    let i = 0;
    while i < k {
        p = next_prime(p);
        i = i + 1;
    }
    return p;
}

fn main() -> i32 {
    std::putint(nth_prime(1));
    std::putch(32);
    std::putint(nth_prime(5));
    std::putch(32);
    std::putint(nth_prime(10));
    std::putch(32);
    std::putint(nth_prime(25));
    std::putch(10);

    let c = 0;
    let v = 2;
    while c < 5 {
        let verdict = is_prime(v);
        if verdict == 1 {
            std::putint(v);
            std::putch(32);
            c = c + 1;
        }
        v = v + 1;
    }
    std::putch(10);

    return 0;
}
